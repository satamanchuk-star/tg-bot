# =============================================================================
# Пример конфигурации AlexBot.
#
# Секреты живут ТОЛЬКО в секретах:
#   - локально: скопируйте этот файл в .env и заполните (в git .env не коммитится);
#   - на сервере: всё содержимое .env кладётся в ОДИН GitHub-секрет BOT_ENV,
#     деплой-пайплайн (.github/workflows/build.yml) пишет его в /opt/alexbot/.env.
# Никакого хранения токенов/ключей в docker-compose на сервере больше нет.
# =============================================================================

# --- Обязательные ---
BOT_TOKEN=
FORUM_CHAT_ID=-1002127934225
ADMIN_LOG_CHAT_ID=-1003697662870

# --- Anthropic Claude API ---
# Ключ Anthropic (https://console.anthropic.com/). Алиасы: AI_KEY, AI_API_KEY.
ANTHROPIC_API_KEY=
AI_ENABLED=true
# Эндпоинт по умолчанию — официальный api.anthropic.com (anthropic SDK).
# Задавайте AI_API_URL только если используете корпоративный прокси к Anthropic.
AI_API_URL=
AI_MODEL=claude-haiku-4-5
AI_TIMEOUT_SECONDS=12
AI_RETRIES=1

# База и системные
# Относительный путь автоматически конвертируется в абсолютный внутри Docker
DATABASE_URL=sqlite+aiosqlite:///app/data/bot.db
TIMEZONE=Europe/Moscow
BUILD_VERSION=dev

# Суточные лимиты AI (по chat_id, по локальной дате TIMEZONE)
AI_DAILY_REQUEST_LIMIT=2000
AI_DAILY_TOKEN_LIMIT=400000

# Включение/отключение отдельных AI-фич
AI_FEATURE_MODERATION=true
AI_FEATURE_ASSISTANT=true
AI_FEATURE_DAILY_SUMMARY=true

# Планировщик ежедневной сводки
AI_SUMMARY_HOUR=21
AI_SUMMARY_MINUTE=0
# Если пусто — сводка уйдет в ADMIN_LOG_CHAT_ID
AI_SUMMARY_TOPIC_ID=

# Топики форума
TOPIC_RULES=93144
TOPIC_IMPORTANT=669
TOPIC_BUILDINGS_41_42=14733
TOPIC_BUILDING_2=14726
TOPIC_BUILDING_3=14725
TOPIC_COMPLAINTS=2982
TOPIC_RIDES=3
TOPIC_SMOKE=410
TOPIC_PETS=7523
TOPIC_REPAIR=1763
TOPIC_REALTY=13074
TOPIC_PARENTS=8
TOPIC_ADS=99
TOPIC_GAMES=4747
TOPIC_GATE=77848
TOPIC_SERVICES=3240
TOPIC_UK=5
TOPIC_NEIGHBORS=164
TOPIC_MARKET=7
TOPIC_DUPLEX=18378

# Утреннее приветствие с погодой и праздниками (8:00 в General)
AI_DAILY_GREETING=false

# Прокси для Telegram API (нужен, только если api.telegram.org заблокирован).
# На зарубежном сервере Telegram доступен напрямую — оставляйте PROXY_ENABLED=false.
PROXY_ENABLED=false
PROXY_MANUAL=

# Google Sheets (импорт инфраструктуры)
GOOGLE_SHEETS_SPREADSHEET_ID=1OsPh54Bn5fdkfsEJyKcbYZTcHnue3EWQ
GOOGLE_SHEETS_WORKSHEET_NAME=Objects
GOOGLE_SERVICE_ACCOUNT_FILE=

# --- AI Multi-model routing (Anthropic Claude) ---
# По умолчанию всё на дешёвом Claude Haiku; Sonnet — только премиум-путь.
AI_CLASSIFIER_MODEL=claude-haiku-4-5
AI_SPAM_MODEL=claude-haiku-4-5
AI_TOPIC_MODEL=claude-haiku-4-5
AI_GATE_INTENT_MODEL=claude-haiku-4-5
AI_MAIN_MODEL=claude-haiku-4-5
AI_FAQ_MODEL=claude-haiku-4-5
AI_REPLY_MODEL=claude-haiku-4-5
AI_DIGEST_MODEL=claude-haiku-4-5
AI_GATE_EXTRACT_MODEL=claude-haiku-4-5
AI_CODE_MODEL=claude-haiku-4-5
# Премиум-ответы (крайние случаи) — Claude Sonnet.
AI_PREMIUM_MODEL=claude-sonnet-4-6
AI_FALLBACK_MODEL=claude-haiku-4-5

# --- AI Extended limits ---
AI_MAX_DAILY_COST_USD=2.00
AI_CLASSIFIER_MAX_OUTPUT_TOKENS=120
AI_REPLY_MAX_OUTPUT_TOKENS=500
AI_DIGEST_MAX_OUTPUT_TOKENS=700
