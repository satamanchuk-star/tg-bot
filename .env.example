# Обязательные
BOT_TOKEN=
FORUM_CHAT_ID=-1002127934225
ADMIN_LOG_CHAT_ID=-1003697662870

# База и системные
# Относительный путь автоматически конвертируется в абсолютный внутри Docker
DATABASE_URL=sqlite+aiosqlite:///app/data/bot.db
TIMEZONE=Europe/Moscow
BUILD_VERSION=dev

# AI базовые настройки
AI_ENABLED=true
AI_API_URL=https://openrouter.ai/api/v1
AI_KEY=
# Альтернативные имена (поддерживаются как алиасы):
OPENROUTER_API_KEY=
AI_API_KEY=
AI_MODEL=anthropic/claude-haiku-4.5
AI_TIMEOUT_SECONDS=12
AI_RETRIES=1

# Суточные лимиты AI (по chat_id, по локальной дате TIMEZONE)
# AI_DAILY_REQUEST_LIMIT: максимум успешных AI-вызовов в сутки
# AI_DAILY_TOKEN_LIMIT: максимум токенов (если провайдер вернул usage.total_tokens)
AI_DAILY_REQUEST_LIMIT=2000
AI_DAILY_TOKEN_LIMIT=400000

# Включение/отключение отдельных AI-фич
AI_FEATURE_MODERATION=true
AI_FEATURE_ASSISTANT=true

# Топики форума
TOPIC_RULES=93144
TOPIC_IMPORTANT=669
TOPIC_BUILDINGS_41_42=14733
TOPIC_BUILDING_2=14726
TOPIC_BUILDING_3=14725
TOPIC_COMPLAINTS=2982
TOPIC_RIDES=3      # топик «Попутчики» — бот не отвечает там вообще
TOPIC_SMOKE=410
TOPIC_PETS=7523
TOPIC_REPAIR=1763
TOPIC_REALTY=13074
TOPIC_PARENTS=8
TOPIC_ADS=99
TOPIC_GAMES=4747
TOPIC_GATE=77848
TOPIC_SERVICES=3240
TOPIC_UK=5
TOPIC_NEIGHBORS=164
TOPIC_MARKET=7
TOPIC_DUPLEX=18378

# Утреннее приветствие с погодой и праздниками (8:00 в General)
AI_DAILY_GREETING=false

# Прокси для Telegram API (если api.telegram.org заблокирован).
# PROXY_ENABLED=true  — автоматический поиск рабочих прокси из публичных списков
# PROXY_MANUAL        — конкретный прокси (приоритет над PROXY_ENABLED)
# Формат PROXY_MANUAL: socks5://user:pass@ip:1080  или  http://user:pass@ip:3128
PROXY_ENABLED=false
PROXY_MANUAL=

# Google Sheets (импорт инфраструктуры)
GOOGLE_SHEETS_SPREADSHEET_ID=1OsPh54Bn5fdkfsEJyKcbYZTcHnue3EWQ
GOOGLE_SHEETS_WORKSHEET_NAME=Objects
GOOGLE_SERVICE_ACCOUNT_FILE=
